<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{30}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- App code: DEBUG so auth and service detail is visible -->
    <logger name="com.adoptu" level="DEBUG"/>

    <!-- Silence noisy infrastructure libs -->
    <logger name="org.jetbrains.exposed" level="WARN"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="software.amazon.awssdk" level="WARN"/>
    <logger name="org.apache.http" level="WARN"/>
    <logger name="com.webauthn4j" level="INFO"/>
    <logger name="org.koin" level="INFO"/>
    <logger name="io.ktor.server.plugins.calllogging" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
